{
  "name": "gryt-ui-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Workspace for @gryt/ui, the React component library for Gryt.",
  "homepage": "https://gryt.chat",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gryt-chat/gryt-ui.git"
  },
  "bugs": {
    "url": "https://github.com/Gryt-chat/gryt/issues"
  },
  "packageManager": "bun@1.2.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --filter @gryt/docs dev",
    "build": "bun --filter '*' build",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun --filter @gryt/ui test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  }
}

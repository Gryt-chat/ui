{
  "name": "@gryt/ui",
  "version": "0.1.0",
  "description": "React component library for Gryt, the open-source WebRTC voice chat platform.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://gryt.chat",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gryt-chat/gryt-ui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/Gryt-chat/gryt/issues"
  },
  "keywords": [
    "gryt",
    "gryt-chat",
    "react",
    "mui",
    "material-ui",
    "tailwindcss",
    "components",
    "design-system",
    "voice-chat"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && bun scripts/fix-declarations.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  },
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0",
    "react-dom": ">=18.3.0 || >=19.0.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.6",
    "@mui/system": "^7.3.6",
    "@phosphor-icons/react": "^2.1.10",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "jsdom": "^27.3.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.16"
  }
}
